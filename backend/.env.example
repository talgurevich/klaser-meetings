# App
APP_ENV=development
LOG_LEVEL=INFO

# Database — meetings' own DB. Only meeting-specific data lives here
# (meetings, transcripts, protocols, …). Never a users/tenants table —
# see app/models.py and docs/identity-cutover.md in klaser-identity.
DATABASE_URL=postgresql+psycopg://meetings:meetings@localhost:5434/meetings

# Identity service — every auth call goes here instead of a local
# users/tenants table. See app/services/identity.py.
IDENTITY_URL=http://localhost:8001
# Bearer token for /api/service/* calls (background jobs, cron). Must
# match one of the entries in klaser-identity's SERVICE_TOKENS env var.
IDENTITY_SERVICE_TOKEN=

# CORS — this backend's product frontend(s)
FRONTEND_URL=http://localhost:5174
