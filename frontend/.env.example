# This product's own backend
VITE_API_BASE_URL=http://localhost:8002

# Identity service — every auth call (login, register, /me, logout,
# tenant-switch, password reset) goes here, never to the Meetings backend.
VITE_IDENTITY_BASE_URL=http://localhost:8001

# Same Google OAuth Client ID as klaser-identity's GOOGLE_CLIENT_ID — used
# by the "Sign up with Google" button on /register. This origin
# (http://localhost:5174 in dev) must also be listed under "Authorized
# JavaScript origins" for that client in Google Cloud Console. Leave
# empty to omit the Google button; email+password registration still works.
VITE_GOOGLE_CLIENT_ID=
